# Copy this file to .env and fill in your values

# FREE option (recommended): sign up at https://console.groq.com — no credit
# card needed — create an API key, and paste it here. Leave OPENAI_API_KEY
# blank/unset if you're using this.
GROQ_API_KEY=gsk_...your-groq-key-here...

# PAID alternative: if you'd rather use OpenAI instead of Groq, leave
# GROQ_API_KEY blank and set this instead (costs a small amount per request).
OPENAI_API_KEY=

# Optional: restrict which website origin can call this backend
# (leave as * while testing locally)
ALLOWED_ORIGIN=*

# Optional: override the model. Defaults to llama-3.3-70b-versatile for Groq,
# or gpt-4o-mini for OpenAI, depending on which key above is set.
VOICENAV_MODEL=

# Optional: port to listen on (defaults to 3001)
PORT=3001
